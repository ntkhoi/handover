{
  "manifest_version": 3,
  "name": "Lark Base Analytics",
  "version": "0.1.0",
  "description": "Reads the currently open Lark Base (Bitable) table and produces a summary analytics report you can export.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.larksuite.com/*",
    "https://*.feishu.cn/*",
    "https://*.feishu.net/*"
  ],
  "action": {
    "default_title": "Lark Base Analytics",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.larksuite.com/base/*",
        "https://*.feishu.cn/base/*",
        "https://*.feishu.net/base/*"
      ],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.larksuite.com/base/*",
        "https://*.feishu.cn/base/*",
        "https://*.feishu.net/base/*"
      ],
      "js": ["src/lark-core.js", "src/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
